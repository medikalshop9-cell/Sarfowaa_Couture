rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Check Firestore role (mirrors frontend isAdmin check)
    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Products ──────────────────────────────────────────────────────────────
    match /products/{productId} {
      allow read: if true;               // Public catalog
      allow create, update, delete: if isAdmin();
    }

    // ── Categories ────────────────────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Hero Banners ──────────────────────────────────────────────────────────
    match /banners/{bannerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ── Orders ────────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // Owner can read their own order; admin can read all
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid);

      // Create: must be authenticated or guest (userId may be null).
      // The backend API handles creation, but allow direct create for fallback.
      allow create: if
        request.resource.data.keys().hasAll(['customer', 'items', 'total', 'status']) &&
        request.resource.data.status == 'pending_payment';

      // Update: admin only (status changes, etc.)
      allow update: if isAdmin();

      // Delete: admin only
      allow delete: if isAdmin();
    }

    // ── Inquiries ─────────────────────────────────────────────────────────────
    match /inquiries/{inquiryId} {
      // Anyone can submit an inquiry (the backend API handles this)
      allow create: if
        request.resource.data.keys().hasAll(['name', 'email', 'message']);

      // Only admin can read, update (mark read), or delete
      allow read, update, delete: if isAdmin();
    }

    // ── Site Settings ─────────────────────────────────────────────────────────
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Users can read and write their own profile
      allow read: if isOwner(userId) || isAdmin();

      // Allow create on registration
      allow create: if isOwner(userId);

      // Allow update of own profile, but not the role field
      allow update: if isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
        || isAdmin();

      allow delete: if isAdmin();
    }

  }
}
