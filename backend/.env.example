# ── Server ───────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173

# ── Firebase Admin SDK ───────────────────────────────────
# Path to the service-account JSON relative to /backend
FIREBASE_SERVICE_ACCOUNT_PATH=../sarfowaa-351b7-firebase-adminsdk-fbsvc-13891f47ae.json
FIREBASE_STORAGE_BUCKET=sarfowaa-351b7.firebasestorage.app

# ── Email / SMTP ─────────────────────────────────────────
# Gmail example: enable 2FA → create App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# Display name + from address for outgoing emails
EMAIL_FROM="Sarfowaa's Couture <hello@sarfowaa.com>"

# Where admin order / inquiry notifications are sent
ADMIN_EMAIL=hello@sarfowaa.com
